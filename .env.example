# --- Contact form (use one approach) ---

# Option A — Resend (recommended for Vercel): https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=
# One-time: push .env.local to Vercel — create token at https://vercel.com/account/tokens
# export VERCEL_TOKEN=... && npm run env:vercel
# Must be a sender Resend allows (verify domain in production). Default works for testing:
# CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# Option B — SMTP (e.g. Gmail with app password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_TO_EMAIL=
